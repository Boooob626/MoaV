# MoaV Stealth Frontend — Caddy TLS terminator + XHTTP reverse proxy
# Routes XHTTP traffic to Xray, serves static HTML decoy to everyone else
# Anti-active-probing defense for GFW (China) and RKN (Russia)

:443 {
	# Self-signed TLS certificate (generated by bootstrap.sh)
	tls /state/keys/stealth/cert.pem /state/keys/stealth/key.pem {
		protocols tls1.2 tls1.3
	}

	# XHTTP proxy traffic — route to Xray internal port
	handle /{$XHTTP_STEALTH_PATH}/* {
		reverse_proxy xray:8443 {
			# Pass through without modifying headers
			# XHTTP handles its own protocol framing
			flush_interval -1
		}
	}

	# Default: serve static decoy website
	handle {
		root * /srv/html
		try_files {path} /index.html
		file_server
		encode gzip
	}

	# Minimal logging (no request paths logged to avoid leaking stealth path)
	log {
		output stdout
		format console
		level ERROR
	}
}
